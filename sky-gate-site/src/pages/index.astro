---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import QuickActionGrid from '../components/QuickActionGrid.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout
  title="Home"
  description="Sky Gate strata community in Langford, BC — helpful information for residents, owners, and visitors."
>
  <Hero />
  <QuickActionGrid />

  <!-- Property Management -->
  <section class="py-16 px-4 bg-white" aria-labelledby="mgmt-heading">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="flex-1">
          <p class="text-gold font-semibold text-sm uppercase tracking-widest mb-2">Property Management</p>
          <h2 id="mgmt-heading" class="text-3xl font-bold text-navy mb-4 tracking-tight">
            Managed by Proline Management Ltd.
          </h2>
          <p class="text-slate-600 mb-4 leading-relaxed">
            Sky Gate is professionally managed by <strong>Proline Management Ltd.</strong>,
            providing expert strata management services for our community's day-to-day needs.
          </p>
          <p class="text-slate-600 mb-6 leading-relaxed">
            For maintenance requests, owner documents, strata records, and correspondence,
            use the StrataPress Resident Portal.
          </p>
          <div class="flex flex-wrap gap-3">
            <CTAButton href="https://portal.stratapress.com/" label="Resident Portal" variant="primary" external={true} />
            <CTAButton href="https://www.prolinemanagement.com/" label="Proline Website" variant="secondary" external={true} />
          </div>
        </div>
        <div class="flex-shrink-0 w-full md:w-auto">
          <img
            src="/images/SkyGate.jpg"
            alt="Sky Gate community"
            class="w-full max-w-sm mx-auto rounded-2xl shadow-xl object-cover h-64"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Location banner -->
  <section class="py-14 px-4 bg-gradient-to-r from-navy to-navy-light text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl font-bold mb-3">Sky Gate — Langford, BC</h2>
      <p class="text-blue-100 max-w-xl mx-auto leading-relaxed">
        A modern strata community on Vancouver Island. Questions? Use the Resident Portal
        or contact Proline Management for any strata-related matters.
      </p>
    </div>
  </section>
</BaseLayout>
