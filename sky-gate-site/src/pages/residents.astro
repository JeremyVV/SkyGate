---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import AlertBox from '../components/AlertBox.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout
  title="Residents"
  description="Information for Sky Gate residents — reporting issues, documents, and community living."
>
  <PageHeader
    title="For Residents"
    description="Everything you need to know about living at Sky Gate."
    breadcrumb="Residents"
  />

  <div class="max-w-4xl mx-auto px-4 py-12 space-y-14">

    <!-- Owner's Guide -->
    <section aria-labelledby="owners-guide-heading">
      <div class="flex flex-col sm:flex-row items-start gap-6 bg-gradient-to-br from-navy to-navy-light text-white rounded-2xl p-6 sm:p-8 shadow-lg">
        <div class="flex-shrink-0 w-14 h-14 bg-white/15 rounded-2xl flex items-center justify-center text-3xl" aria-hidden="true">
          📘
        </div>
        <div class="flex-1">
          <h2 id="owners-guide-heading" class="text-xl font-bold mb-2">Sky Gate Owner's Guide</h2>
          <p class="text-blue-100 text-sm leading-relaxed mb-5">
            The Sky Gate Owner's Guide covers everything you need to know as a strata owner —
            building systems, suite information, community expectations, and key contacts.
            A helpful reference for new and existing owners alike.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="/docs/SG-OWNERS-GUIDE-2023.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-gold text-white font-semibold rounded-xl hover:bg-gold-dark transition-colors text-sm"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              View Guide (PDF)
            </a>
            <a
              href="/docs/SG-OWNERS-GUIDE-2023.pdf"
              download="SG-Owners-Guide-2023.pdf"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/15 border border-white/30 text-white font-semibold rounded-xl hover:bg-white/25 transition-colors text-sm"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Download
            </a>
          </div>
          <p class="mt-3 text-blue-300 text-xs">Sky Gate Owner's Guide — 2023 edition &nbsp;·&nbsp; PDF, 6.3 MB</p>
        </div>
      </div>
    </section>

    <!-- Reporting Issues -->
    <section aria-labelledby="issues-heading">
      <h2 id="issues-heading" class="text-2xl font-bold text-navy mb-4">Reporting Issues</h2>
      <p class="text-slate-600 mb-5 leading-relaxed">
        Found something that needs attention? All maintenance requests and issue reports are handled
        through the <strong>StrataPress Resident Portal</strong>. This ensures your request is
        properly logged, tracked, and assigned to the right person.
      </p>
      <AlertBox type="info" title="How to report">
        <p>Log in to the Resident Portal, navigate to <em>Maintenance</em>, and submit a request. Include photos and a clear description for faster resolution.</p>
      </AlertBox>
      <div class="mt-5">
        <CTAButton href="https://portal.stratapress.com/" label="Submit a Report" variant="primary" external={true} />
      </div>
    </section>

    <!-- Documents -->
    <section aria-labelledby="docs-heading">
      <h2 id="docs-heading" class="text-2xl font-bold text-navy mb-4">Owner Documents &amp; Records</h2>
      <p class="text-slate-600 mb-4 leading-relaxed">
        All strata documents are available through the StrataPress portal. Access is provided to
        owners and tenants by Proline Management.
      </p>
      <ul class="space-y-2 mb-6">
        {[
          'Strata bylaws and rules',
          'Meeting minutes and AGM packages',
          'Financial statements',
          'Owner correspondence',
          'Strata forms and requests',
        ].map(item => (
          <li class="flex items-center gap-2 text-slate-600">
            <span class="w-5 h-5 rounded-full bg-skyblue/10 text-skyblue flex items-center justify-center text-xs font-bold flex-shrink-0" aria-hidden="true">✓</span>
            {item}
          </li>
        ))}
      </ul>
      <CTAButton href="https://portal.stratapress.com/" label="Access Documents" variant="secondary" external={true} />
    </section>

    <!-- Living guidelines -->
    <section aria-labelledby="living-heading">
      <h2 id="living-heading" class="text-2xl font-bold text-navy mb-5">Living at Sky Gate</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          { title: 'Be a considerate neighbour', desc: 'Keep noise minimal, especially between 10 pm and 8 am. Shared walls and floors carry sound.' },
          { title: 'Common areas', desc: 'Hallways, elevators, and amenities are shared. Treat them with care and leave them clean.' },
          { title: 'Pets in common areas', desc: 'Keep pets leashed at all times in common areas. Clean up promptly. Refer to the bylaws for pet policies.' },
          { title: 'Moves & large deliveries', desc: 'Book elevator access in advance through Proline Management for any moves or oversized deliveries.' },
          { title: 'Smoking & vaping', desc: 'Sky Gate is strictly non-smoking. Smoking, vaping, and the use of e-cigarettes or similar devices are not permitted anywhere on the property — including inside suites, on balconies, in common areas, or anywhere on the grounds.' },
          { title: 'Alterations', desc: 'Any modifications to your unit require strata council approval. Submit a request via the portal before starting work.' },
        ].map(item => (
          <div class="bg-slate-50 rounded-2xl p-5">
            <h3 class="font-semibold text-navy mb-1.5">{item.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Package Deliveries -->
    <section aria-labelledby="packages-heading">
      <h2 id="packages-heading" class="text-2xl font-bold text-navy mb-5">📦 Package Deliveries</h2>

      <div class="space-y-6">

        <!-- Receiving Deliveries -->
        <div class="bg-slate-50 rounded-2xl p-6">
          <h3 class="font-semibold text-navy text-lg mb-3">Receiving Deliveries at Sky Gate</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-3">
            Sky Gate does not provide secured parcel storage. Deliveries may be left in common areas such as the lobby or mail area.
          </p>
          <p class="text-slate-600 text-sm leading-relaxed mb-3">
            Packages left unattended in these areas are at increased risk of loss or theft.
          </p>
          <p class="text-slate-600 text-sm leading-relaxed">
            If you choose to have items delivered to common areas, please understand that this is at your own risk, and the strata corporation cannot guarantee the security of unattended parcels.
          </p>
        </div>

        <!-- Reducing the Risk -->
        <div class="bg-slate-50 rounded-2xl p-6">
          <h3 class="font-semibold text-navy text-lg mb-3">📉 Reducing the Risk</h3>
          <p class="text-slate-600 text-sm mb-4">To help ensure your deliveries arrive safely, consider:</p>
          <ul class="space-y-2">
            {[
              'Requesting signature-required delivery',
              'Using carrier pickup locations (e.g., post office or depot)',
              'Scheduling deliveries when someone is home',
              'Delivering to a workplace or alternate secure address',
            ].map(item => (
              <li class="flex items-start gap-2 text-slate-600 text-sm">
                <span class="w-5 h-5 rounded-full bg-skyblue/10 text-skyblue flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5" aria-hidden="true">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- If a Package Is Missing -->
        <div class="bg-slate-50 rounded-2xl p-6">
          <h3 class="font-semibold text-navy text-lg mb-3">🚨 If a Package Is Missing</h3>
          <p class="text-slate-600 text-sm mb-4">If your package cannot be located:</p>
          <ul class="space-y-2">
            {[
              'Contact the courier or retailer directly to report the issue',
              'Provide delivery details in writing to property management',
            ].map(item => (
              <li class="flex items-start gap-2 text-slate-600 text-sm">
                <span class="w-5 h-5 rounded-full bg-skyblue/10 text-skyblue flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5" aria-hidden="true">✓</span>
                {item}
              </li>
            ))}
          </ul>
          <p class="text-slate-500 text-sm mt-4 italic">This helps ensure the situation is documented and can be reviewed if needed.</p>
        </div>

        <!-- A Shared Space -->
        <div class="bg-slate-50 rounded-2xl p-6">
          <h3 class="font-semibold text-navy text-lg mb-3">🤝 A Shared Space</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Common areas are shared by all residents and are not monitored for parcel storage. Taking a few extra steps when arranging deliveries helps reduce issues and keeps the building running smoothly for everyone.
          </p>
        </div>

        <!-- Tip callout -->
        <AlertBox type="info" title="Tip">
          <p>Enable delivery notifications on your phone so you can retrieve packages as soon as they arrive.</p>
        </AlertBox>

        <!-- Courier instructions -->
        <div class="border-2 border-slate-200 rounded-2xl p-6">
          <h3 class="font-semibold text-navy text-lg mb-2">📦 Delivery Instructions (for Couriers)</h3>
          <p class="text-slate-600 text-sm leading-relaxed font-medium">
            Do not leave unattended. Buzz resident or redirect to pickup location.
          </p>
        </div>

      </div>
    </section>

    <!-- Management CTA -->
    <section aria-labelledby="mgmt-cta-heading" class="bg-gradient-to-r from-navy to-navy-light rounded-2xl p-8 text-white">
      <h2 id="mgmt-cta-heading" class="text-xl font-bold mb-3">Need to Contact Management?</h2>
      <p class="text-blue-100 mb-6 leading-relaxed">
        Sky Gate is managed by <strong>Proline Management Ltd.</strong> For non-emergency
        questions, use the Resident Portal or visit their website.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="https://portal.stratapress.com/" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-1 px-5 py-2.5 bg-gold text-white font-semibold rounded-xl hover:bg-gold-dark transition-colors text-sm">
          Resident Portal ↗
        </a>
        <a href="https://www.prolinemanagement.com/" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-1 px-5 py-2.5 border-2 border-white/60 text-white font-semibold rounded-xl hover:bg-white/10 transition-colors text-sm">
          Proline Website ↗
        </a>
        <a href="/contact"
           class="inline-flex items-center gap-1 px-5 py-2.5 border-2 border-white/60 text-white font-semibold rounded-xl hover:bg-white/10 transition-colors text-sm">
          Contact Info →
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
