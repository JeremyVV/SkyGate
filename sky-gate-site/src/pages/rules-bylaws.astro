---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import AlertBox from '../components/AlertBox.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout
  title="Rules & Bylaws"
  description="Sky Gate strata bylaws and community rules — available through the StrataPress Resident Portal."
>
  <PageHeader
    title="Rules &amp; Bylaws"
    description="The official rules and bylaws that govern our community."
    breadcrumb="Rules & Bylaws"
  />

  <div class="max-w-4xl mx-auto px-4 py-12 space-y-10">

    <AlertBox type="info" title="Official documents are in the Resident Portal">
      <p>The full, legally current strata bylaws and rules are hosted in the <strong>StrataPress Resident Portal</strong>. Only documents stored there are official. Links below require a portal account.</p>
    </AlertBox>

    <!-- Direct document links -->
    <section aria-labelledby="docs-heading">
      <h2 id="docs-heading" class="text-2xl font-bold text-navy mb-5">Access the Documents</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <a
          href="https://portal.stratapress.com/dashboard/documents/manage/1009/37344"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-4 bg-white rounded-2xl shadow-md hover:shadow-lg border border-slate-100 hover:border-skyblue transition-all p-6 focus-visible:ring-2 focus-visible:ring-skyblue focus-visible:ring-offset-2 focus:outline-none"
        >
          <span class="text-4xl flex-shrink-0" aria-hidden="true">📜</span>
          <div>
            <p class="font-bold text-navy text-lg group-hover:text-skyblue transition-colors">Current Bylaws</p>
            <p class="text-slate-500 text-sm mt-1 leading-relaxed">The legally filed strata bylaws. Requires portal login.</p>
            <span class="mt-3 inline-flex items-center text-skyblue text-sm font-semibold">Open in portal ↗</span>
          </div>
        </a>

        <a
          href="https://portal.stratapress.com/dashboard/documents/manage/1009/37345"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-4 bg-white rounded-2xl shadow-md hover:shadow-lg border border-slate-100 hover:border-skyblue transition-all p-6 focus-visible:ring-2 focus-visible:ring-skyblue focus-visible:ring-offset-2 focus:outline-none"
        >
          <span class="text-4xl flex-shrink-0" aria-hidden="true">📋</span>
          <div>
            <p class="font-bold text-navy text-lg group-hover:text-skyblue transition-colors">Community Rules</p>
            <p class="text-slate-500 text-sm mt-1 leading-relaxed">The strata rules adopted by council. Requires portal login.</p>
            <span class="mt-3 inline-flex items-center text-skyblue text-sm font-semibold">Open in portal ↗</span>
          </div>
        </a>

      </div>
    </section>

    <!-- Owner's Guide cross-link -->
    <div class="flex items-center gap-4 bg-slate-50 border border-slate-200 rounded-2xl px-6 py-4">
      <span class="text-3xl flex-shrink-0" aria-hidden="true">📘</span>
      <div class="flex-1 min-w-0">
        <p class="font-semibold text-navy text-sm">Sky Gate Owner's Guide (2023)</p>
        <p class="text-slate-500 text-xs mt-0.5">A practical reference covering building expectations alongside the formal bylaws.</p>
      </div>
      <a
        href="/docs/SG-OWNERS-GUIDE-2023.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="flex-shrink-0 inline-flex items-center gap-1 px-4 py-2 bg-navy text-white text-xs font-semibold rounded-xl hover:bg-navy-light transition-colors whitespace-nowrap"
      >
        View PDF
      </a>
    </div>

    <section aria-labelledby="about-heading">
      <h2 id="about-heading" class="text-2xl font-bold text-navy mb-4">About Our Bylaws</h2>
      <p class="text-slate-600 mb-4 leading-relaxed">
        Strata bylaws are the legal rules that govern how Sky Gate operates and how residents
        live together. They cover everything from noise and renovations to pets and parking.
        All residents and owners are expected to be familiar with the bylaws.
      </p>
      <p class="text-slate-600 leading-relaxed">
        Bylaws are adopted and amended by owners at general meetings. The most recent version
        is always available in the Resident Portal.
      </p>
    </section>

    <section aria-labelledby="topics-heading">
      <h2 id="topics-heading" class="text-2xl font-bold text-navy mb-5">Common Topics Covered</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5">
        {[
          'Noise and quiet hours',
          'Pets and animals',
          'Rentals and tenancies',
          'Parking and storage',
          'Alterations and renovations',
          'Move-in and move-out procedures',
          'Balconies and patios',
          'Common property use',
          'Dispute resolution',
          'Smoking and substance use',
          'Short-term rentals (Airbnb)',
          'Strata fees and special levies',
        ].map(topic => (
          <div class="flex items-center gap-2 bg-slate-50 rounded-xl px-4 py-3 text-sm text-slate-700">
            <span class="text-skyblue flex-shrink-0" aria-hidden="true">→</span>
            {topic}
          </div>
        ))}
      </div>
    </section>

    <section aria-labelledby="access-heading">
      <h2 id="access-heading" class="text-2xl font-bold text-navy mb-4">Don't Have Portal Access?</h2>
      <p class="text-slate-600 mb-5 leading-relaxed">
        If you're an owner or tenant who doesn't yet have Resident Portal access, contact
        Proline Management to get set up.
      </p>
      <div class="flex flex-wrap gap-3">
        <CTAButton href="https://portal.stratapress.com/" label="Resident Portal" variant="primary" external={true} />
        <CTAButton href="https://www.prolinemanagement.com/" label="Contact Proline" variant="outline" external={true} />
      </div>
    </section>

  </div>
</BaseLayout>
