---
const navItems = [
  { label: 'Home', href: '/' },
];

const residentsItems = [
  { label: 'Owners & Residents', href: '/residents' },
  { label: 'Rules & Bylaws', href: '/rules-bylaws' },
  { label: 'Condos for Sale', href: '/homes-for-sale' },
];

const buildingItems = [
  { label: 'Amenities', href: '/amenities' },
  { label: 'Neighborhood', href: '/neighborhood' },
  { label: 'Visitor Parking', href: '/visitor-parking' },
  { label: 'EV Charging', href: '/ev-charging' },
  { label: 'Garbage & Recycling', href: '/garbage-recycling' },
  { label: 'Property Map', href: '/property-map' },
];

const contactItems = [
  { label: 'Contact', href: '/contact' },
  { label: 'Emergency Help', href: '/emergency' },
  { label: 'Trades Access', href: '/trades-access' },
];

const currentPath = Astro.url.pathname;
const residentsActive = residentsItems.some(i => i.href === currentPath);
const buildingActive = buildingItems.some(i => i.href === currentPath);
const contactActive = contactItems.some(i => i.href === currentPath);
---

<header class="bg-navy sticky top-0 z-50 shadow-lg" data-pagefind-ignore>
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 rounded focus-visible:ring-2 focus-visible:ring-white">
        <img src="/images/SG-logo-white-300x209.png" alt="Sky Gate" class="h-9 w-auto" />
        <span class="text-white font-semibold text-base hidden sm:block tracking-wide">Sky Gate</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden xl:flex items-center gap-0.5" aria-label="Main navigation">

        {navItems.map(item => (
          <a
            href={item.href}
            class={`px-3 py-2 rounded-lg text-xs font-medium transition-colors whitespace-nowrap ${
              currentPath === item.href
                ? 'bg-navy-light text-white'
                : 'text-blue-100 hover:bg-navy-light hover:text-white'
            }`}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}

        <!-- Owners & Residents dropdown -->
        <div class="relative" id="residents-dropdown-wrapper">
          <button
            id="residents-dropdown-btn"
            class={`flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium transition-colors whitespace-nowrap ${
              residentsActive
                ? 'bg-navy-light text-white'
                : 'text-blue-100 hover:bg-navy-light hover:text-white'
            }`}
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="residents-dropdown"
          >
            Owners &amp; Residents
            <svg class="w-3 h-3 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="residents-dropdown"
            class="hidden absolute right-0 top-full mt-1 w-44 bg-white rounded-xl shadow-xl border border-slate-100 py-1 z-50"
            role="menu"
          >
            {residentsItems.map(item => (
              <a
                href={item.href}
                class={`block px-4 py-2.5 text-sm transition-colors rounded-lg mx-1 ${
                  currentPath === item.href
                    ? 'bg-skyblue/10 text-navy font-semibold'
                    : 'text-slate-700 hover:bg-slate-50 hover:text-navy'
                }`}
                role="menuitem"
                aria-current={currentPath === item.href ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Building & Property dropdown -->
        <div class="relative" id="building-dropdown-wrapper">
          <button
            id="building-dropdown-btn"
            class={`flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium transition-colors whitespace-nowrap ${
              buildingActive
                ? 'bg-navy-light text-white'
                : 'text-blue-100 hover:bg-navy-light hover:text-white'
            }`}
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="building-dropdown"
          >
            Building &amp; Property
            <svg class="w-3 h-3 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="building-dropdown"
            class="hidden absolute right-0 top-full mt-1 w-48 bg-white rounded-xl shadow-xl border border-slate-100 py-1 z-50"
            role="menu"
          >
            {buildingItems.map(item => (
              <a
                href={item.href}
                class={`block px-4 py-2.5 text-sm transition-colors rounded-lg mx-1 ${
                  currentPath === item.href
                    ? 'bg-skyblue/10 text-navy font-semibold'
                    : 'text-slate-700 hover:bg-slate-50 hover:text-navy'
                }`}
                role="menuitem"
                aria-current={currentPath === item.href ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Contact dropdown -->
        <div class="relative" id="contact-dropdown-wrapper">
          <button
            id="contact-dropdown-btn"
            class={`flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium transition-colors whitespace-nowrap ${
              contactActive
                ? 'bg-navy-light text-white'
                : 'text-blue-100 hover:bg-navy-light hover:text-white'
            }`}
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="contact-dropdown"
          >
            Contact
            <svg class="w-3 h-3 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="contact-dropdown"
            class="hidden absolute right-0 top-full mt-1 w-44 bg-white rounded-xl shadow-xl border border-slate-100 py-1 z-50"
            role="menu"
          >
            {contactItems.map(item => (
              <a
                href={item.href}
                class={`block px-4 py-2.5 text-sm transition-colors rounded-lg mx-1 ${
                  currentPath === item.href
                    ? 'bg-skyblue/10 text-navy font-semibold'
                    : 'text-slate-700 hover:bg-slate-50 hover:text-navy'
                }`}
                role="menuitem"
                aria-current={currentPath === item.href ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>

      </nav>

      <!-- Right side: Portal button + search + hamburger -->
      <div class="flex items-center gap-2">
        <a
          href="https://portal.stratapress.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center px-4 py-2 bg-gold text-white text-xs font-bold rounded-xl hover:bg-gold-dark transition-colors whitespace-nowrap"
        >
          Resident Portal
        </a>
        <a
          href="/search"
          class="p-2 rounded-lg text-blue-100 hover:bg-navy-light transition-colors"
          aria-label="Search"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </a>
        <button
          id="nav-toggle"
          class="xl:hidden p-2 rounded-lg text-blue-100 hover:bg-navy-light focus-visible:ring-2 focus-visible:ring-white"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle navigation menu"
        >
          <svg id="icon-menu" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden xl:hidden pb-4" role="navigation" aria-label="Mobile navigation">
      <nav class="flex flex-col gap-1">
        {navItems.map(item => (
          <a
            href={item.href}
            class={`px-4 py-3 rounded-xl text-sm font-medium transition-colors ${
              currentPath === item.href
                ? 'bg-navy-light text-white'
                : 'text-blue-100 hover:bg-navy-light hover:text-white'
            }`}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}

        <!-- Owners & Residents group -->
        <div class="mt-1 pt-2 border-t border-navy-light">
          <p class="px-4 pb-1 text-xs text-blue-400 uppercase tracking-wider font-semibold">Owners &amp; Residents</p>
          {residentsItems.map(item => (
            <a
              href={item.href}
              class={`block px-4 py-3 rounded-xl text-sm font-medium transition-colors ${
                currentPath === item.href
                  ? 'bg-navy-light text-white'
                  : 'text-blue-100 hover:bg-navy-light hover:text-white'
              }`}
              aria-current={currentPath === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>

        <!-- Building & Property group -->
        <div class="mt-1 pt-2 border-t border-navy-light">
          <p class="px-4 pb-1 text-xs text-blue-400 uppercase tracking-wider font-semibold">Building &amp; Property</p>
          {buildingItems.map(item => (
            <a
              href={item.href}
              class={`block px-4 py-3 rounded-xl text-sm font-medium transition-colors ${
                currentPath === item.href
                  ? 'bg-navy-light text-white'
                  : 'text-blue-100 hover:bg-navy-light hover:text-white'
              }`}
              aria-current={currentPath === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>

        <!-- Contact group -->
        <div class="mt-1 pt-2 border-t border-navy-light">
          <p class="px-4 pb-1 text-xs text-blue-400 uppercase tracking-wider font-semibold">Contact</p>
          {contactItems.map(item => (
            <a
              href={item.href}
              class={`block px-4 py-3 rounded-xl text-sm font-medium transition-colors ${
                currentPath === item.href
                  ? 'bg-navy-light text-white'
                  : 'text-blue-100 hover:bg-navy-light hover:text-white'
              }`}
              aria-current={currentPath === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>

        <a
          href="https://portal.stratapress.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 px-4 py-3 bg-gold text-white text-sm font-bold rounded-xl hover:bg-gold-dark text-center"
        >
          Resident Portal ↗
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  // Hamburger
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Generic dropdown factory
  function initDropdown(btnId: string, menuId: string) {
    const btn = document.getElementById(btnId);
    const drop = document.getElementById(menuId);
    if (!btn || !drop) return;

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !drop.classList.contains('hidden');
      // Close all dropdowns first
      document.querySelectorAll('[data-dropdown]').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('[data-dropdown-btn]').forEach(el => el.setAttribute('aria-expanded', 'false'));
      if (!isOpen) {
        drop.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  }

  initDropdown('residents-dropdown-btn', 'residents-dropdown');
  initDropdown('building-dropdown-btn', 'building-dropdown');
  initDropdown('contact-dropdown-btn', 'contact-dropdown');

  // Mark dropdowns for the generic close handler
  document.getElementById('residents-dropdown')?.setAttribute('data-dropdown', '');
  document.getElementById('building-dropdown')?.setAttribute('data-dropdown', '');
  document.getElementById('contact-dropdown')?.setAttribute('data-dropdown', '');
  document.getElementById('residents-dropdown-btn')?.setAttribute('data-dropdown-btn', '');
  document.getElementById('building-dropdown-btn')?.setAttribute('data-dropdown-btn', '');
  document.getElementById('contact-dropdown-btn')?.setAttribute('data-dropdown-btn', '');

  document.addEventListener('click', () => {
    document.querySelectorAll('[data-dropdown]').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('[data-dropdown-btn]').forEach(el => el.setAttribute('aria-expanded', 'false'));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('[data-dropdown]').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('[data-dropdown-btn]').forEach(el => el.setAttribute('aria-expanded', 'false'));
    }
  });
</script>
