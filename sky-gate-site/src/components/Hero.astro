---
interface Props {
  headline?: string;
  subheadline?: string;
  showButtons?: boolean;
}

const {
  headline = 'Welcome to Sky Gate',
  subheadline = 'Helpful information for residents, owners, and visitors.',
  showButtons = true,
} = Astro.props;
---

<section class="relative min-h-[65vh] flex items-center justify-center overflow-hidden" aria-label="Welcome">
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/SkyGate-header.jpg"
      alt="Sky Gate building"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-navy/75 via-navy/65 to-navy/85"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-3xl mx-auto py-16 sm:py-24">
    <img
      src="/images/SG-logo-white-300x209.png"
      alt=""
      class="h-14 sm:h-20 w-auto mx-auto mb-5 sm:mb-6 opacity-90 drop-shadow-lg"
      aria-hidden="true"
    />
    <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 drop-shadow-lg tracking-tight">
      {headline}
    </h1>
    <p class="text-lg sm:text-xl text-blue-100 mb-8 sm:mb-10 max-w-xl mx-auto leading-relaxed">
      {subheadline}
    </p>
    {showButtons && (
      <div class="flex flex-wrap gap-3 justify-center">
        <a
          href="https://portal.stratapress.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-gold text-white font-semibold rounded-xl shadow-lg hover:bg-gold-dark transition-colors text-base"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Report an Issue
        </a>
        <a
          href="https://portal.stratapress.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white/20 backdrop-blur border border-white/50 text-white font-semibold rounded-xl hover:bg-white/30 transition-colors text-base"
        >
          Resident Portal
        </a>
        <a
          href="/emergency"
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-red-400/80 text-white font-semibold rounded-xl hover:bg-red-500/25 transition-colors text-base"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          Emergency Help
        </a>
      </div>
    )}
  </div>
</section>
