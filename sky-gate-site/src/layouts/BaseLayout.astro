---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  headExtra?: string;
}

const {
  title,
  description = 'Sky Gate strata community in Langford, BC — helpful information for residents, owners, and visitors.',
  image = '/images/SkyGate-header.jpg',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | Sky Gate`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/png" href="/images/SG-logo-color.png" />
    <title>{title} | Sky Gate</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-navy text-white px-4 py-2 rounded-lg z-50 font-semibold">
      Skip to main content
    </a>
    <Header />
    <main id="main-content" class="flex-grow" tabindex="-1" data-pagefind-body>
      <slot />
    </main>
    <Footer />
  </body>
</html>
